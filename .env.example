# Root compose env. Copy to .env and fill in.
# These are read by docker-compose.yml for build args / interpolation.
# Per-service secrets live in backend/.env and frontend/.env.

# Frontend → backend base URL (browser-reachable)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Powabase project, browser-safe values (from the Connect modal)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.p.powabase.ai
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLISHABLE_KEY
