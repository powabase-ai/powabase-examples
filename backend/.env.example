# Backend env. Copy to backend/.env and fill in.
# SERVER-SIDE ONLY — never expose these to the browser.

# --- Powabase project (from the Studio → Connect modal) ---
POWABASE_BASE_URL=https://YOUR_REF.p.powabase.ai
POWABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET_KEY
POWABASE_DATABASE_URL=postgresql://USER:PASSWORD@db.YOUR_REF.p.powabase.ai:5432/postgres
POWABASE_JWT_SECRET=YOUR_JWT_SECRET

# --- Powabase resource ids (set once provisioned in the project) ---
RESEARCH_AGENT_ID=
GENERATION_WORKFLOW_ID=
BRAND_KB_ID=

# --- Server ---
CORS_ALLOW_ORIGINS=http://localhost:3000
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
