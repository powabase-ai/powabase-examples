# Frontend env. Copy to frontend/.env and fill in.
# Only browser-safe values belong here (NEXT_PUBLIC_*).

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Powabase project, browser-safe (from the Connect modal)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.p.powabase.ai
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLISHABLE_KEY
