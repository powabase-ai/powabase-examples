# RankForge frontend env. Copy to frontend/.env and fill in.
# Only browser-safe values belong here. Everything is bundled into the client, so
# NEVER put the Service Role key, JWT secret, or Database URL here — only the Anon
# (publishable) key is exposed client-side.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000           # RankForge backend base URL.

# --- Powabase project, browser-safe (from the Connect modal) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.p.powabase.ai  # Project URL (for GoTrue auth).
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLISHABLE_KEY  # Anon (publishable) key ONLY — never the service role key.
