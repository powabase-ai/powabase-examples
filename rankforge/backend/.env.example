# RankForge backend env. Copy to backend/.env and fill in.
# Values come from the Powabase project's Studio -> Connect modal.
#
# !!! The three vars marked [SECRET] are SERVER-ONLY and must NEVER reach the
# !!! browser: do not prefix them with NEXT_PUBLIC_ or ship them to the frontend.
# !!! The frontend gets only the Anon key (see frontend/.env.example).

# --- Powabase project ---
POWABASE_BASE_URL=https://YOUR_REF.p.powabase.ai          # Project URL.
POWABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET_KEY    # [SECRET] RLS-bypassing Service Role key.
POWABASE_DATABASE_URL=postgresql://USER:PASSWORD@db.YOUR_REF.p.powabase.ai:5432/postgres  # [SECRET] Direct Postgres URL.
POWABASE_JWT_SECRET=YOUR_JWT_SECRET                       # [SECRET] Verifies end-user GoTrue tokens.

# --- Powabase resource ids (set once provisioned in the project) ---
RESEARCH_AGENT_ID=                                        # Research agent id for the research pipeline.
GENERATION_WORKFLOW_ID=                                   # Workflow id for article generation.
BRAND_KB_ID=                                              # Brand knowledge-base id grounding generation.

# --- Server ---
CORS_ALLOW_ORIGINS=http://localhost:3000                 # Comma-separated allowed CORS origins (the frontend URL).
PUBLIC_BASE_URL=http://localhost:3000                     # Frontend base URL (where it serves), used to build crawlable /p/{id} links.
DB_POOL_MIN_SIZE=1                                        # Min DB pool connections.
DB_POOL_MAX_SIZE=10                                       # Max DB pool connections.
MAX_BACKGROUND_TASKS=4                                    # Max concurrent heavy background tasks (generation/research/refine/scout).
